DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resale_shopping"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Для Resend: адрес с доменом, подтверждённым в Resend. Формат: "Resale Shopping <orders@ваш-домен.ru>"
# Или только email: orders@ваш-домен.ru — обернётся автоматически.
# RESEND_FROM — приоритетный отправитель именно для Resend (если задан, пробуется первым).
RESEND_FROM=""
ORDER_FROM_EMAIL="Resale Shopping <orders@resale-shopping.ru>"
# Ответы клиентов (Reply-To); не обязателен
ORDER_REPLY_TO_EMAIL="help@resale-shopping.ru"
# Куда слать заявки «Продать» (иначе ORDER_REPLY_TO_EMAIL / help@resale-shopping.ru)
# SELL_LEAD_TO="help@resale-shopping.ru"
RESEND_API_KEY=""
# Опционально: SMTP хостинга (если не задано — для заказов на .ru/.su/.рф используется relay Resend:
# smtp.resend.com, логин resend, пароль = RESEND_API_KEY — отдельные SMTP_* не обязательны).
# RESEND_SMTP_RELAY_DISABLED=1 — не использовать relay, только свой SMTP или HTTP API.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
# RESEND_SMTP_HOST="smtp.resend.com"
# RESEND_SMTP_PORT="465"
# Обязателен для NextAuth: без него /api/auth/* и клик по OAuth дают «Server error / server configuration»
AUTH_SECRET=""
# Сгенерировать: openssl rand -base64 32
#
# Yandex OAuth: в консоли Redirect URI = {AUTH_URL}/api/auth/callback/yandex
# Пример production: https://resale-shopping.ru/api/auth/callback/yandex
# НЕ указывайте /my-account/ — это не OAuth callback.
AUTH_URL=""
AUTH_YANDEX_ID=""
AUTH_YANDEX_SECRET=""
# Опционально: кнопка Yandex на /auth/signin включается и по AUTH_YANDEX_ID+SECRET при рендере страницы (без пересборки).
# NEXT_PUBLIC_AUTH_YANDEX_ENABLED=1 — только если нужна подсветка в чисто клиентских местах.
NEXT_PUBLIC_AUTH_YANDEX_ENABLED="0"

# Вход email+пароль: таблица CredentialUser — после обновления схемы выполните prisma migrate deploy
